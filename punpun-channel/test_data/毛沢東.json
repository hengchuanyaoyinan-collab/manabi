        "keyword": "毛沢東 真剣",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 64,
      "chapter": 4,
      "chapter_title": "",
      "text": "全国の農民に『バックヤード製鉄所を作れ』と命令します。",
