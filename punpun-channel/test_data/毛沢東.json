        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 60,
      "chapter": 3,
      "chapter_title": "",
      "text": "でも、ここからが違う。",
      "emotion": "think",
      "image_hint": {
        "type": "portrait",
        "keyword": "毛沢東 沈黙",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 61,
      "chapter": 4,
      "chapter_title": "",
      "text": "1958年。毛沢東は『大躍進』を宣言します。",
