        "keyword": "農民 命令 強制",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 65,
      "chapter": 4,
      "chapter_title": "",
      "text": "5億人の農民が、農業を放っぽり出して…",
