        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 59,
      "chapter": 3,
      "chapter_title": "",
      "text": "ここまで、まだ『良い話』の領域です。",
