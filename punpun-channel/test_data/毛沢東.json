        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 57,
      "chapter": 3,
      "chapter_title": "",
      "text": "中国全土に彼の肖像画が飾られるようになります。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "肖像画 壁 崇拝",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 58,
      "chapter": 3,
      "chapter_title": "",
      "text": "人民は『毛主席は間違わない』と信じます。",
      "emotion": "shock",
      "image_hint": {
