      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 48,
      "chapter": 3,
      "chapter_title": "",
      "text": "人口5億5,000万。当時の世界人口の4分の1です。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "人口 大勢 群衆",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 49,
      "chapter": 3,
      "chapter_title": "",
      "text": "『貧しい農民の息子が、ここまで来た』と思いませんか?",
      "emotion": "think",
      "image_hint": {
        "type": "portrait",
        "keyword": "毛沢東 勝利者",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 50,
      "chapter": 3,
      "chapter_title": "",
      "text": "農地改革を断行して、農民から地主の土地を奪いました。",
