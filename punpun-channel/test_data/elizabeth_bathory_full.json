      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 3,
      "chapter": 0,
      "chapter_title": "",
      "text": "何百人もの女性に危害を加えたとされる、16世紀ハンガリーの貴族なんですよね。",
      "image_hint": {
        "type": "map_historical",
