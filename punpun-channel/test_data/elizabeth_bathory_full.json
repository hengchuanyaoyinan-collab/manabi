        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 17,
      "chapter": 2,
      "chapter_title": "",
      "text": "城で働く若い使用人の女性たちが、次々と消えたり、傷だらけになって戻ってくるんですね。",
