    {
      "index": 14,
      "chapter": 2,
      "chapter_title": "",
      "text": "若くして、何百人もの使用人を持つ、莫大な権力を手にするわけです。",
      "image_hint": {
        "type": "illustration",
        "keyword": "城での権力",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 15,
      "chapter": 2,
      "chapter_title": "",
      "text": "この時点では、まだ彼女は普通の貴族夫人だったんですよね。",
      "image_hint": {
        "type": "portrait",
        "keyword": "エリザベート・バートリ",
        "highlight": null,
        "overlay_keyword": null,
