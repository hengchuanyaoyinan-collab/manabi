        "overlay_keyword": null,
        "annotation": "16世紀の結婚式"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 12,
      "chapter": 2,
      "chapter_title": "",
      "text": "結婚後、夫はオスマン帝国との戦争に出ていくんですよね。",
      "image_hint": {
        "type": "map_historical",
        "keyword": "オスマン帝国とハンガリーの戦争",
