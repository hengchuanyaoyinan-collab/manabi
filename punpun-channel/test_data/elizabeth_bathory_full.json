  "chapters": [
    {
      "index": 0,
      "title": "オープニング",
      "summary": "ぷんぷんが視聴者に挨拶し、『血の伯爵夫人』エリザベート・バートリという人物の紹介と、今回のやばエピソードへのフックを提示する。"
    },
    {
      "index": 1,
      "title": "生い立ち",
      "summary": "1560年ハンガリーに生まれた富豪貴族の娘。両親の愛情、教育、美貌に恵まれた幼少期から、15歳での結婚までを描く。"
    },
    {
      "index": 2,
      "title": "結婚と権力",
      "summary": "ナダスディ伯爵との結婚後、夫が戦地に赴く。城での権力が増す中で、使用人への虐待行為が徐々に始まる様子を描く。"
    },
    {
      "index": 3,
      "title": "狂気の始まり",
      "summary": "1580年代から1600年代初期、虐待がエスカレート。若さを保つための儀式という名目で、数百人の若い使用人が被害を受け始める。"
    },
    {
      "index": 4,
      "title": "やばい行動の数々",
      "summary": "虐待と拷問の具体例、被害者たちの証言、そして逮捕に至るまでの経過を描く。社会的地位がいかに彼女を守ってきたかも描写。"
    },
    {
      "index": 5,
      "title": "最期",
      "summary": "1610年の逮捕、裁判での証言、そして17年間の幽閉生活。1614年の死まで。"
    },
    {
      "index": 6,
      "title": "まとめ",
      "summary": "歴史的意義、権力と監視の重要性、そして吸血鬼伝説の起源。教訓と次回予告、チャンネル登録の呼びかけ。"
    }
  ],
  "scenes": [
    {
      "index": 0,
