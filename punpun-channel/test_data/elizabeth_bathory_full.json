        "keyword": "城の地下",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": "拷問が行われた場所"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 25,
      "chapter": 3,
      "chapter_title": "",
      "text": "その被害者の数は、公式記録では300人以上。民間伝承では数千人とも言われてるんですね。",
      "image_hint": {
        "type": "illustration",
        "keyword": "犠牲者",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 26,
      "chapter": 3,
      "chapter_title": "",
      "text": "300人ですよ。300人。イメージできます？すごくやばいじゃないですか。",
      "image_hint": {
        "type": "illustration",
        "keyword": "悲劇",
        "highlight": null,
        "overlay_keyword": null,
