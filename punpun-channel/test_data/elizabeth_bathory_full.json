        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 5,
      "chapter": 1,
      "chapter_title": "",
      "text": "エリザベート・バートリは1560年ごろ、ハンガリーの最高級貴族に生まれるんですよ。",
      "image_hint": {
        "type": "photo",
        "keyword": "ハンガリー古城",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": "バートリ家の城"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 6,
      "chapter": 1,
      "chapter_title": "",
      "text": "両親はめちゃくちゃ権力のある貴族で、彼女も当時最高の教育を受けたんですよね。",
      "image_hint": {
        "type": "illustration",
        "keyword": "貴族の子ども教育",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": "16世紀の貴族教育"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 7,
      "chapter": 1,
      "chapter_title": "",
      "text": "語学、音楽、作法...全部できたんですよ。ほんと、親には恵まれてたんです。",
      "image_hint": {
        "type": "illustration",
        "keyword": "女性の教育",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 8,
      "chapter": 1,
      "chapter_title": "",
      "text": "さらに美貌にも恵まれていて、当時の記録でも『美しい令嬢』と書かれてるんですよね。",
      "image_hint": {
        "type": "portrait",
        "keyword": "若きエリザベート・バートリ",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": "美貌で知られた肖像"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 9,
      "chapter": 1,
      "chapter_title": "",
      "text": "まさに何もかもに恵まれた、ハンガリー貴族の『完璧な令嬢』だったわけです。",
      "image_hint": {
        "type": "illustration",
        "keyword": "幸福な女性",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 10,
      "chapter": 1,
      "chapter_title": "",
      "text": "ところが15歳の時、ナダスディ・フェレンツという大貴族と結婚させられるんですよね。",
      "image_hint": {
        "type": "portrait",
        "keyword": "ナダスディ・フェレンツ",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": "夫となった貴族"
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 11,
      "chapter": 1,
      "chapter_title": "",
      "text": "当時は15歳での結婚なんて珍しくないんですけど、この結婚がターニングポイントになるんですよ。",
      "image_hint": {
        "type": "illustration",
        "keyword": "貴族の結婚式",
