    {
      "index": 37,
      "chapter": 3,
      "chapter_title": "",
      "text": "プロシアとの戦争に勝ってたのに、急に降伏した。",
      "emotion": "shock",
      "image_hint": {
        "type": "map_historical",
        "keyword": "七年戦争 プロシア ロシア",
        "highlight": null,
        "overlay_keyword": "ピョートル3世",
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 38,
      "chapter": 3,
      "chapter_title": "",
      "text": "理由は？フリードリヒ大王が好きだから。",
      "emotion": "angry",
      "image_hint": {
