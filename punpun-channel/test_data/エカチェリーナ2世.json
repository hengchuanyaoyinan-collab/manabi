        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 39,
      "chapter": 3,
      "chapter_title": "",
      "text": "貴族たちもキレた。「この皇帝、大丈夫か？」",
      "emotion": "angry",
      "image_hint": {
        "type": "illustration",
        "keyword": "貴族 怒り 会議",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 40,
      "chapter": 3,
      "chapter_title": "",
      "text": "エカチェリーナは気づいた。このままじゃダメだ。",
      "emotion": "think",
      "image_hint": {
        "type": "illustration",
        "keyword": "女性 決意 目つき",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 41,
