        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 39,
      "chapter": 3,
      "chapter_title": "",
      "text": "ここに至って、ハンガリアの有力貴族たちが動きます。調査に乗り出したんです。",
      "emotion": "normal",
      "image_hint": {
        "type": "illustration",
