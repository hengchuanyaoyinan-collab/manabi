        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 38,
      "chapter": 3,
      "chapter_title": "",
      "text": "エリザベートは、貴族の娘も狙い始めたんです。その子たちも失踪。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "貴族 娘 失踪 肖像画",
