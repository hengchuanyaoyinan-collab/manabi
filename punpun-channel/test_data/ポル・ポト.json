    {
      "index": 18,
      "chapter": 2,
      "chapter_title": "",
      "text": "当時のパリは、知識人の間で共産主義が大流行。",
      "emotion": "normal",
      "image_hint": {
        "type": "illustration",
        "keyword": "パリ カフェ 知識人 議論 1950 年代",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 19,
      "chapter": 2,
      "chapter_title": "",
      "text": "彼も虜になりました。「平等な社会を作ろう」って。",
      "emotion": "think",
      "image_hint": {
        "type": "illustration",
        "keyword": "平等 理想 ユートピア 赤い旗",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
