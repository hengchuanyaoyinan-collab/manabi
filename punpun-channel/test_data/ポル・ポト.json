        "keyword": "ポル・ポト 若い時代 1950 年代",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 16,
      "chapter": 1,
      "chapter_title": "",
      "text": "ここまでの話、ただのエリート秀才ですよね。",
      "emotion": "normal",
      "image_hint": {
        "type": "blank",
        "keyword": "",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
