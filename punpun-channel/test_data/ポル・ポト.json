      "chapter": 2,
      "chapter_title": "",
      "text": "「現体制は腐ってる。徹底的に破壊すべき」",
      "emotion": "angry",
      "image_hint": {
        "type": "illustration",
        "keyword": "破壊 革命 炎 激怒",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 26,
      "chapter": 2,
      "chapter_title": "",
      "text": "1956 年、獄中から脱獄します。",
      "emotion": "shock",
      "image_hint": {
