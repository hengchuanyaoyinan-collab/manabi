        "type": "blank",
        "keyword": "",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 2,
      "chapter": 0,
      "chapter_title": "",
      "text": "この人、ポル・ポト。聞いたことあります？",
      "emotion": "think",
      "image_hint": {
        "type": "portrait",
        "keyword": "ポル・ポト 肖像",
        "highlight": null,
        "overlay_keyword": null,
