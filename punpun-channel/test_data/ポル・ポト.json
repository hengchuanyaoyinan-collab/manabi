      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 79,
      "chapter": 5,
      "chapter_title": "",
      "text": "部下たちが… 彼を逮捕しました。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "逮捕 拘束 牢獄",
        "highlight": null,
        "overlay_keyword": "ポル・ポト",
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 80,
      "chapter": 5,
      "chapter_title": "",
      "text": "1998 年 4 月 15 日。ポル・ポト、獄死します。",
      "emotion": "normal",
      "image_hint": {
        "type": "illustration",
        "keyword": "死 終焉 静寂",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 81,
      "chapter": 5,
      "chapter_title": "",
      "text": "69 歳。国際法廷で裁かれることなく… 死にました。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "法廷 裁判 正義",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 82,
      "chapter": 5,
      "chapter_title": "",
      "text": "300 万人以上の命を… 説明することなく。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "追悼 記念碑 骸骨",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 83,
      "chapter": 5,
      "chapter_title": "",
      "text": "でも、遺骨は…『キリングフィールド』に埋葬されました。",
