      "chapter": 1,
      "chapter_title": "",
      "text": "で、ポル・ポトをプノンペンの一流学校に入れました。",
      "emotion": "normal",
      "image_hint": {
        "type": "illustration",
        "keyword": "学校 生徒 勉強",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
