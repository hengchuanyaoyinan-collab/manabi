    {
      "index": 11,
      "chapter": 1,
      "chapter_title": "",
      "text": "そこで成績優秀だったんです。将来有望なエリート。",
      "emotion": "normal",
      "image_hint": {
        "type": "portrait",
        "keyword": "ポル・ポト 学生 若い",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 12,
      "chapter": 1,
      "chapter_title": "",
      "text": "1949 年、ついにフランスに留学しました。",
      "emotion": "normal",
      "image_hint": {
        "type": "map_historical",
        "keyword": "フランス パリ 1949 年",
        "highlight": "フランス",
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 13,
      "chapter": 1,
      "chapter_title": "",
      "text": "パリの大学で工学を学ぶ。まじで優秀。",
      "emotion": "normal",
      "image_hint": {
