        "overlay_keyword": "ポル・ポト",
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 76,
      "chapter": 5,
      "chapter_title": "",
      "text": "米国とタイは、反共の名目で… 彼を支援しました。",
      "emotion": "angry",
      "image_hint": {
        "type": "map_historical",
        "keyword": "米国 タイ 冷戦 1980 年代",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 77,
      "chapter": 5,
      "chapter_title": "",
      "text": "冷戦下では… 敵の敵は味方だったんです。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "冷戦 東西対立 米ソ",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 78,
      "chapter": 5,
      "chapter_title": "",
      "text": "1997 年、クメール・ルージュの内部で反乱が起きます。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "反乱 反逆 銃撃 組織分裂",
        "highlight": null,
        "overlay_keyword": null,
