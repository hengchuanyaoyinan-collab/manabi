        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 51,
      "chapter": 3,
      "chapter_title": "",
      "text": "…いや、どういう神経してるんですか、本当に。",
      "emotion": "angry",
      "image_hint": {
        "type": "blank",
        "keyword": "",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 52,
      "chapter": 4,
      "chapter_title": "",
      "text": "殺害は組織的でした。秘密警察『トゥール・スレン』。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "刑務所 牢獄 暗い 恐怖",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 53,
      "chapter": 4,
      "chapter_title": "",
      "text": "捕まった者は、拷問され、自白を強要されました。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "拷問 苦悶 牢獄",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 54,
      "chapter": 4,
      "chapter_title": "",
      "text": "「反革命活動をしたか」「スパイか」と。",
      "emotion": "normal",
      "image_hint": {
        "type": "illustration",
        "keyword": "尋問 審問 黒板 記録",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 55,
      "chapter": 4,
      "chapter_title": "",
      "text": "でも… 実はみんな無実だったんです。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
