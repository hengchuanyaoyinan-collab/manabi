      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 4,
      "chapter": 0,
      "chapter_title": "",
      "text": "うち医者は全員、教師も全員。知識人なら容赦なし。",
      "emotion": "angry",
      "image_hint": {
        "type": "illustration",
        "keyword": "医者 教師 知識人",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 5,
      "chapter": 0,
      "chapter_title": "",
      "text": "最後に、彼がどう転落したか。見ていきましょう。",
      "emotion": "think",
      "image_hint": {
        "type": "blank",
        "keyword": "",
        "highlight": null,
