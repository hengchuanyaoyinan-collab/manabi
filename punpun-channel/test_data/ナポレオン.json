      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 50,
      "chapter": 5,
      "chapter_title": "",
      "text": "イギリス、ロシア、プロイセン、オーストリアが団結。",
      "emotion": "normal",
      "image_hint": {
        "type": "map_historical",
        "keyword": "ヨーロッパ連合 1813年",
        "highlight": "同盟国",
