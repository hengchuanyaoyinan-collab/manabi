      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 51,
      "chapter": 5,
      "chapter_title": "",
      "text": "1813年。ライプツィヒの戦い。ナポレオン、敗北。",
      "emotion": "shock",
      "image_hint": {
        "type": "illustration",
        "keyword": "敗北 戦場",
        "highlight": null,
        "overlay_keyword": null,
