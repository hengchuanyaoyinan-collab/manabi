      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 47,
      "chapter": 5,
      "chapter_title": "",
      "text": "兵士たちが次々と死んでいく。60万人が…",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "兵士 死 雪原",
        "highlight": null,
        "overlay_keyword": null,
