      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 49,
      "chapter": 5,
      "chapter_title": "",
      "text": "この戦いが、ナポレオンの全てを奪った。",
      "emotion": "sad",
      "image_hint": {
