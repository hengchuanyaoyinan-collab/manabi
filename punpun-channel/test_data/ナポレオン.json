      "audio_path": null
    },
    {
      "index": 52,
      "chapter": 5,
      "chapter_title": "",
      "text": "1814年。ナポレオン、退位を強要されます。",
      "emotion": "sad",
      "image_hint": {
        "type": "illustration",
        "keyword": "王冠 失う 悲劇",
        "highlight": null,
        "overlay_keyword": null,
        "annotation": null
      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 53,
      "chapter": 5,
      "chapter_title": "",
      "text": "皇帝は終わり。今度は流刑人。",
      "emotion": "sad",
