      },
      "duration_seconds": null,
      "audio_path": null
    },
    {
      "index": 48,
      "chapter": 5,
      "chapter_title": "",
      "text": "最終的に帰ってきたのは、たった2万人。",
      "emotion": "sad",
      "image_hint": {
