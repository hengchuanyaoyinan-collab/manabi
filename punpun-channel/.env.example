# YouTube Data API v3
# https://console.cloud.google.com/ で取得
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# YouTube Data API v3 (読み取り専用 API キー・競合分析用)
# Cloud Console で API キーを発行: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_api_key_here

# VOICEVOX Engine
VOICEVOX_URL=http://localhost:50021

# Whisper (ローカル or OpenAI API)
WHISPER_MODE=local
OPENAI_API_KEY=optional_for_whisper_api

# 動画出力先
OUTPUT_DIR=./output

# テストモード (true なら YouTube アップロードしない)
TEST_MODE=true

# Discord 通知 (任意)
# Discord のチャンネル設定 → インテグレーション → ウェブフック → 新しいウェブフック で発行
DISCORD_WEBHOOK_URL=

# ElevenLabs 声クローン (任意、$5/月 Starter プランで十分)
# https://elevenlabs.io で登録 → API → API キー
# Voice ID は Voices → Add a New Voice → Instant Voice Cloning で取得
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OpenAI gpt-image-1 シーン画像生成 (任意)
# https://platform.openai.com で API キー発行
# 1 枚 $0.042 程度、1 動画 100 枚で $4.2
OPENAI_API_KEY=
