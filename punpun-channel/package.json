{
  "name": "punpun-channel",
  "version": "0.1.0",
  "description": "ぷんぷんの世事見聞録 - 完全自動化動画制作パイプライン",
  "private": true,
  "scripts": {
    "generate": "python3 src/orchestrator.py",
    "generate:test": "python3 src/orchestrator.py --test",
    "voicevox:test": "python3 src/voice/voicevox_client.py --test",
    "remotion:studio": "npx remotion studio remotion/src/index.ts",
    "remotion:render": "npx remotion render remotion/src/index.ts PunpunVideo out/video.mp4",
    "youtube:auth": "python3 src/upload/youtube_oauth.py",
    "youtube:upload": "python3 src/upload/upload_video.py",
    "thumbnail:test": "python3 src/video/thumbnail_generator.py --test"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@remotion/zod-types": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remotion": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
